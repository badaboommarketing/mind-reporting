{
  "name": "mind-reporting",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "db:apply-schema": "node --import tsx src/scripts/apply-schema.ts",
    "db:seed": "node --import tsx src/scripts/seed-bootstrap.ts",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/time.test.ts test/identity.test.ts test/reporting.test.ts test/sync-policy.test.ts test/csv-import.test.ts"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.30",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "csv-parse": "^6.2.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0"
  }
}
